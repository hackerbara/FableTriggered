      "seconds": 0.7
    },
    {
      "type": "key",
      "key": "down"
    },
    {
      "type": "wait",
      "seconds": 5
    },
    {
      "type": "key",
      "key": "x"
    },
    {
      "type": "wait",
      "seconds": 5
    },
    {
      "type": "key",
      "key": "ctrl-c"
    }
  ],
  "publish": {
    "enabled": false,
    "outputGif": "/Users/MAC/Documents/Claude-patch/assets/demos/hidden-context-plus-hotrod-dragons-open-drawer.gif"
  }
